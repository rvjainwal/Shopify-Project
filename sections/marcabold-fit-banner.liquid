{% liquid
  assign left_asset = section.settings.left_fallback_asset
  if left_asset == blank
    assign left_asset = 'marcabold-fit-left-alt.png'
  endif

  assign right_asset = section.settings.right_fallback_asset
  if right_asset == blank
    assign right_asset = 'marcabold-fit-right.png'
  endif

  assign banner_link = section.settings.banner_link
  if banner_link == blank
    assign banner_link = routes.all_products_collection_url
  endif

  assign button_link = section.settings.button_link
  if button_link == blank
    assign button_link = banner_link
  endif
%}

<section
  id="MarcaboldFitBanner-{{ section.id }}"
  class="marcabold-fit-banner"
  style="
    --mfb-bg: {{ section.settings.background_color }};
    --mfb-text: {{ section.settings.text_color }};
    --mfb-max-width: {{ section.settings.max_width }}px;
    --mfb-height: {{ section.settings.desktop_height }}px;
    --mfb-mobile-height: {{ section.settings.mobile_height }}px;
    --mfb-side-padding: {{ section.settings.side_padding }}px;
    --mfb-padding-top: {{ section.settings.padding_top }}px;
    --mfb-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="marcabold-fit-banner__inner">
    <div class="marcabold-fit-banner__media">
      <a
        class="marcabold-fit-banner__image-link"
        href="{{ banner_link }}"
        aria-label="{{ section.settings.heading | escape }}"
      ></a>

      <div class="marcabold-fit-banner__panel marcabold-fit-banner__panel--left">
        {% if section.settings.left_image != blank %}
          {{
            section.settings.left_image
            | image_url: width: 1800
            | image_tag:
              widths: '480, 720, 960, 1200, 1600, 1800',
              sizes: '(min-width: 750px) 50vw, 100vw',
              class: 'marcabold-fit-banner__image',
              loading: 'lazy',
              alt: section.settings.left_image.alt
          }}
        {% else %}
          <img
            class="marcabold-fit-banner__image"
            src="{{ left_asset | asset_url }}"
            alt="{{ section.settings.heading | escape }}"
            width="683"
            height="650"
            loading="lazy"
          >
        {% endif %}
      </div>

      <div class="marcabold-fit-banner__panel marcabold-fit-banner__panel--right">
        {% if section.settings.right_image != blank %}
          {{
            section.settings.right_image
            | image_url: width: 1800
            | image_tag:
              widths: '480, 720, 960, 1200, 1600, 1800',
              sizes: '(min-width: 750px) 50vw, 100vw',
              class: 'marcabold-fit-banner__image',
              loading: 'lazy',
              alt: section.settings.right_image.alt
          }}
        {% else %}
          <img
            class="marcabold-fit-banner__image"
            src="{{ right_asset | asset_url }}"
            alt="{{ section.settings.heading | escape }}"
            width="683"
            height="650"
            loading="lazy"
          >
        {% endif %}
      </div>

      <div class="marcabold-fit-banner__content">
        {% if section.settings.eyebrow != blank %}
          <p class="marcabold-fit-banner__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="marcabold-fit-banner__heading">{{ section.settings.heading | escape }}</h2>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <a class="marcabold-fit-banner__button" href="{{ button_link }}">
            {{ section.settings.button_label | escape }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .marcabold-fit-banner {
    display: block;
    padding: var(--mfb-padding-top) var(--mfb-side-padding) var(--mfb-padding-bottom);
    background: var(--mfb-bg);
  }

  .marcabold-fit-banner__inner {
    width: min(var(--mfb-max-width), 100%);
    margin-inline: auto;
  }

  .marcabold-fit-banner__media {
    position: relative;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    height: var(--mfb-height);
    overflow: hidden;
  }

  .marcabold-fit-banner__image-link {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .marcabold-fit-banner__panel {
    min-width: 0;
    height: 100%;
    overflow: hidden;
    background: #ddd3c2;
  }

  .marcabold-fit-banner__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .marcabold-fit-banner__panel--left .marcabold-fit-banner__image {
    object-position: center;
  }

  .marcabold-fit-banner__panel--right .marcabold-fit-banner__image {
    object-position: center;
  }

  .marcabold-fit-banner__content {
    position: absolute;
    z-index: 3;
    left: 50%;
    bottom: 30px;
    display: flex;
    width: min(676px, calc(100% - 40px));
    flex-direction: column;
    align-items: center;
    color: var(--mfb-text);
    text-align: center;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .marcabold-fit-banner__eyebrow,
  .marcabold-fit-banner__heading {
    margin: 0;
    color: inherit;
    letter-spacing: 0;
    text-align: center;
  }

  .marcabold-fit-banner__eyebrow {
    margin-bottom: -5px;
    font-family: Satoshi, Inter, var(--font-body--family), sans-serif;
    font-size: 16px;
    font-weight: 900;
    line-height: 22px;
    text-transform: uppercase;
  }

  .marcabold-fit-banner__heading {
    font-family: Overpass, Inter, var(--font-heading--family), sans-serif;
    font-size: 34px;
    font-weight: 800;
    line-height: 1.04;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .marcabold-fit-banner__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 99px;
    height: 47px;
    margin-top: 5px;
    padding: 0 17px;
    border: 1px solid #000000;
    border-radius: 64px;
    background: #ffffff;
    color: #000000;
    font-family: Satoshi, Inter, var(--font-body--family), sans-serif;
    font-size: 14px;
    font-weight: 500;
    line-height: normal;
    text-decoration: none;
    pointer-events: auto;
  }

  @media screen and (max-width: 749px) {
    .marcabold-fit-banner {
      padding: 24px 12px 44px;
    }

    .marcabold-fit-banner__media {
      grid-template-columns: 1fr;
      height: var(--mfb-mobile-height);
    }

    .marcabold-fit-banner__panel--right {
      display: none;
    }

    .marcabold-fit-banner__content {
      bottom: 22px;
      width: min(340px, calc(100% - 24px));
    }

    .marcabold-fit-banner__eyebrow {
      margin-bottom: 0;
      font-size: 12px;
      line-height: 16px;
    }

    .marcabold-fit-banner__heading {
      font-size: 24px;
      line-height: 1.08;
    }

    .marcabold-fit-banner__button {
      height: 38px;
      min-width: 88px;
      font-size: 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Marcabold fit banner",
  "tag": "section",
  "class": "marcabold-fit-banner-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left image"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right image"
    },
    {
      "type": "text",
      "id": "left_fallback_asset",
      "label": "Left fallback asset filename",
      "default": "marcabold-fit-left-alt.png"
    },
    {
      "type": "text",
      "id": "right_fallback_asset",
      "label": "Right fallback asset filename",
      "default": "marcabold-fit-right.png"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner link"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "TEES THAT ACTUALLY FIT."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Soft fabrics. Relaxed fits. Loud personality."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 1000,
      "max": 1500,
      "step": 10,
      "unit": "px",
      "default": 1370
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop height",
      "min": 400,
      "max": 800,
      "step": 5,
      "unit": "px",
      "default": 650
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 420,
      "max": 720,
      "step": 5,
      "unit": "px",
      "default": 560
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side padding",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 37
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 64
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#efefeb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Marcabold fit banner"
    }
  ]
}
{% endschema %}
