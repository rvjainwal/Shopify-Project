      "step": 1,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "panel_gap",
      "label": "Panel gap",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 42
    },
    {
      "type": "range",
      "id": "input_width",
      "label": "Email width",
      "min": 240,
      "max": 420,
      "step": 10,
      "unit": "px",
      "default": 360
    },
    {
      "type": "range",
      "id": "button_width",
      "label": "Button width",
      "min": 120,
