<section
  id="MarcaboldSizeTiles-{{ section.id }}"
  class="marcabold-size-tiles"
  style="
    --mst-bg: {{ section.settings.background_color }};
    --mst-eyebrow: {{ section.settings.eyebrow_color }};
    --mst-heading: {{ section.settings.heading_color }};
    --mst-label: {{ section.settings.label_color }};
    --mst-max-width: {{ section.settings.max_width }}px;
    --mst-padding-top: {{ section.settings.padding_top }}px;
    --mst-padding-bottom: {{ section.settings.padding_bottom }}px;
    --mst-side-padding: {{ section.settings.side_padding }}px;
    --mst-gap: {{ section.settings.tile_gap }}px;
    --mst-image-height: {{ section.settings.image_height }}px;
    --mst-mobile-image-height: {{ section.settings.mobile_image_height }}px;
  "
>
  <div class="marcabold-size-tiles__inner">
    <div class="marcabold-size-tiles__header">
      {% if section.settings.eyebrow != blank %}
        <p class="marcabold-size-tiles__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="marcabold-size-tiles__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
    </div>

    <div class="marcabold-size-tiles__track">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% liquid
            assign tile_link = block.settings.link
            if tile_link == blank
              assign tile_link = routes.all_products_collection_url
            endif

            assign fallback_asset = block.settings.fallback_asset
            if fallback_asset == blank
              assign fallback_asset = 'marcabold-size-2xl.png'
            endif

            assign image_alt = block.settings.image.alt | default: block.settings.label
            if image_alt == blank
              assign image_alt = shop.name
            endif
          %}

          <a
            class="marcabold-size-tiles__card"
            href="{{ tile_link }}"
            {{ block.shopify_attributes }}
            {% if block.settings.open_in_new_tab %}
              target="_blank" rel="noopener noreferrer"
            {% endif %}
          >
            <picture class="marcabold-size-tiles__media">
              {% if block.settings.mobile_image != blank %}
                <source
                  media="(max-width: 749px)"
                  srcset="
                    {{ block.settings.mobile_image | image_url: width: 360 }} 360w,
                    {{ block.settings.mobile_image | image_url: width: 720 }} 720w,
                    {{ block.settings.mobile_image | image_url: width: 960 }} 960w
                  "
                  sizes="72vw"
                >
              {% endif %}

              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 960
                  | image_tag:
                    widths: '220, 360, 480, 720, 960',
                    sizes: '(min-width: 990px) 20vw, 72vw',
                    class: 'marcabold-size-tiles__image',
                    loading: 'lazy',
                    alt: image_alt
                }}
              {% else %}
                <img
                  class="marcabold-size-tiles__image"
                  src="{{ fallback_asset | asset_url }}"
                  alt="{{ image_alt | escape }}"
                  width="219"
                  height="291"
                  loading="lazy"
                >
              {% endif %}
            </picture>

            {% if block.settings.label != blank %}
              <span class="marcabold-size-tiles__label">{{ block.settings.label | escape }}</span>
            {% endif %}
          </a>
        {% endfor %}
      {% else %}
        {% assign fallback_labels = '2XL,3XL,4XL,5XL,6XL' | split: ',' %}
        {% assign fallback_images = 'marcabold-size-2xl.png,marcabold-size-3xl.png,marcabold-size-4xl.png,marcabold-size-5xl.png,marcabold-size-6xl.png' | split: ',' %}
        {% for label in fallback_labels %}
          <a class="marcabold-size-tiles__card" href="{{ routes.all_products_collection_url }}">
            <picture class="marcabold-size-tiles__media">
              <img
                class="marcabold-size-tiles__image"
                src="{{ fallback_images[forloop.index0] | asset_url }}"
                alt="{{ label | escape }}"
                width="219"
                height="291"
                loading="lazy"
              >
            </picture>
            <span class="marcabold-size-tiles__label">{{ label | escape }}</span>
          </a>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .marcabold-size-tiles {
    display: block;
    padding: var(--mst-padding-top) var(--mst-side-padding) var(--mst-padding-bottom);
    background: var(--mst-bg);
  }

  .marcabold-size-tiles__inner {
    width: min(var(--mst-max-width), 100%);
    margin-inline: auto;
  }

  .marcabold-size-tiles__header {
    margin-bottom: 14px;
    text-align: center;
  }

  .marcabold-size-tiles__eyebrow,
  .marcabold-size-tiles__heading {
    margin: 0;
    letter-spacing: 0;
    text-align: center;
    text-transform: uppercase;
  }

  .marcabold-size-tiles__eyebrow {
    margin-bottom: -5px;
    color: var(--mst-eyebrow);
    font-family: Satoshi, Inter, var(--font-body--family), sans-serif;
    font-size: 14px;
    font-weight: 700;
    line-height: 22px;
  }

  .marcabold-size-tiles__heading {
    color: var(--mst-heading);
    font-family: Overpass, Inter, var(--font-heading--family), sans-serif;
    font-size: 28px;
    font-weight: 800;
    line-height: 1.04;
  }

  .marcabold-size-tiles__track {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: var(--mst-gap);
    align-items: start;
  }

  .marcabold-size-tiles__card {
    display: flex;
    min-width: 0;
    flex-direction: column;
    align-items: center;
    color: var(--mst-label);
    text-decoration: none;
  }

  .marcabold-size-tiles__media {
    display: block;
    width: 100%;
    height: var(--mst-image-height);
    overflow: hidden;
    background: #ddd9cf;
  }

  .marcabold-size-tiles__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 220ms ease;
  }

  .marcabold-size-tiles__card:hover .marcabold-size-tiles__image {
    transform: scale(1.02);
  }

  .marcabold-size-tiles__label {
    display: block;
    width: 100%;
    padding-top: 10px;
    color: inherit;
    font-family: Satoshi, Inter, var(--font-body--family), sans-serif;
    font-size: 14px;
    font-weight: 700;
    line-height: 22px;
    text-align: center;
    letter-spacing: 0;
  }

  @media screen and (max-width: 989px) {
    .marcabold-size-tiles__track {
      display: flex;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-behavior: smooth;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }

    .marcabold-size-tiles__track::-webkit-scrollbar {
      display: none;
    }

    .marcabold-size-tiles__card {
      flex: 0 0 32vw;
      scroll-snap-align: start;
    }
  }

  @media screen and (max-width: 749px) {
    .marcabold-size-tiles {
      padding: 8px 16px 42px;
    }

    .marcabold-size-tiles__heading {
      font-size: 24px;
      line-height: 1.08;
    }

    .marcabold-size-tiles__card {
      flex-basis: 72vw;
    }

    .marcabold-size-tiles__media {
      height: var(--mst-mobile-image-height);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Marcabold size tiles",
  "tag": "section",
  "class": "marcabold-size-tiles-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "SHOP BY SIZE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BUILT TO FIT BIGGER."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 900,
      "max": 1300,
      "step": 10,
      "unit": "px",
      "default": 1100
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side padding",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 37
    },
    {
      "type": "range",
      "id": "tile_gap",
      "label": "Tile gap",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Desktop image height",
      "min": 220,
      "max": 420,
      "step": 5,
      "unit": "px",
      "default": 290
    },
    {
      "type": "range",
      "id": "mobile_image_height",
      "label": "Mobile image height",
      "min": 320,
      "max": 620,
      "step": 5,
      "unit": "px",
      "default": 420
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#efefeb"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#828282"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#212121"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#222222"
    }
  ],
  "blocks": [
    {
      "type": "size",
      "name": "Size tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        },
        {
          "type": "text",
          "id": "fallback_asset",
          "label": "Fallback asset filename",
          "default": "marcabold-size-2xl.png"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "2XL"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "open_in_new_tab",
          "label": "Open in new tab",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marcabold size tiles",
      "blocks": [
        {
          "type": "size",
          "settings": {
            "label": "2XL",
            "link": "shopify://collections/all",
            "fallback_asset": "marcabold-size-2xl.png"
          }
        },
        {
          "type": "size",
          "settings": {
            "label": "3XL",
            "link": "shopify://collections/all",
            "fallback_asset": "marcabold-size-3xl.png"
          }
        },
        {
          "type": "size",
          "settings": {
            "label": "4XL",
            "link": "shopify://collections/all",
            "fallback_asset": "marcabold-size-4xl.png"
          }
        },
        {
          "type": "size",
          "settings": {
            "label": "5XL",
            "link": "shopify://collections/all",
            "fallback_asset": "marcabold-size-5xl.png"
          }
        },
        {
          "type": "size",
          "settings": {
            "label": "6XL",
            "link": "shopify://collections/all",
            "fallback_asset": "marcabold-size-6xl.png"
          }
        }
      ]
    }
  ]
}
{% endschema %}
