{% comment %}
  MCA Final Year Project
  Single Page Online Job Portal System
  Shopify Contact Form Connected
{% endcomment %}

<section id="mca-job-portal-{{ section.id }}" class="mca-job-portal">

  <style>
    #mca-job-portal-{{ section.id }} {
      --primary: #0b5cff;
      --primary-dark: #003db8;
      --secondary: #00b894;
      --dark: #111827;
      --text: #374151;
      --muted: #6b7280;
      --light: #f5f7fb;
      --white: #ffffff;
      --border: #e5e7eb;
      --shadow: 0 20px 45px rgba(15, 23, 42, 0.12);
      --radius: 22px;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--text);
      background: var(--light);
      overflow: hidden;
    }

    #mca-job-portal-{{ section.id }} * {
      box-sizing: border-box;
    }

    #mca-job-portal-{{ section.id }} a {
      text-decoration: none;
      color: inherit;
    }

    #mca-job-portal-{{ section.id }} .jp-container {
      width: min(1180px, 92%);
      margin: 0 auto;
    }

    #mca-job-portal-{{ section.id }} .jp-header {
      position: sticky;
      top: 0;
      z-index: 30;
      background: rgba(255,255,255,0.88);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(229,231,235,0.8);
    }

    #mca-job-portal-{{ section.id }} .jp-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 0;
      gap: 20px;
    }

    #mca-job-portal-{{ section.id }} .jp-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 800;
      color: var(--dark);
      font-size: 22px;
    }

    #mca-job-portal-{{ section.id }} .jp-logo-icon {
      width: 42px;
      height: 42px;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      display: grid;
      place-items: center;
      color: white;
      box-shadow: 0 12px 30px rgba(11, 92, 255, 0.28);
    }

    #mca-job-portal-{{ section.id }} .jp-menu {
      display: flex;
      gap: 24px;
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
    }

    #mca-job-portal-{{ section.id }} .jp-menu a:hover {
      color: var(--primary);
    }

    #mca-job-portal-{{ section.id }} .jp-btn {
      border: none;
      background: var(--primary);
      color: white;
      padding: 13px 20px;
      border-radius: 999px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.3s ease;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      box-shadow: 0 12px 28px rgba(11, 92, 255, 0.24);
    }

    #mca-job-portal-{{ section.id }} .jp-btn:hover {
      transform: translateY(-2px);
      background: var(--primary-dark);
    }

    #mca-job-portal-{{ section.id }} .jp-btn.secondary {
      background: white;
      color: var(--primary);
      border: 1px solid var(--border);
      box-shadow: none;
    }

    #mca-job-portal-{{ section.id }} .jp-auth-actions {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 10px;
      flex-wrap: wrap;
    }

    #mca-job-portal-{{ section.id }} .jp-auth-actions .jp-btn {
      padding: 12px 17px;
      font-size: 13px;
    }

    #mca-job-portal-{{ section.id }} .jp-user-chip {
      display: none;
      align-items: center;
      gap: 10px;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 8px 10px 8px 8px;
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.08);
    }

    #mca-job-portal-{{ section.id }} .jp-user-chip.active {
      display: flex;
    }

    #mca-job-portal-{{ section.id }} .jp-user-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
      font-weight: 900;
      flex: 0 0 auto;
    }

    #mca-job-portal-{{ section.id }} .jp-user-info {
      display: grid;
      line-height: 1.15;
    }

    #mca-job-portal-{{ section.id }} .jp-user-info strong {
      color: var(--dark);
      font-size: 13px;
      max-width: 130px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    #mca-job-portal-{{ section.id }} .jp-user-info small {
      color: var(--muted);
      font-weight: 700;
      font-size: 11px;
    }

    #mca-job-portal-{{ section.id }} .jp-logout {
      border: none;
      background: #f3f4f6;
      color: var(--dark);
      border-radius: 999px;
      padding: 8px 11px;
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
    }

    #mca-job-portal-{{ section.id }} .jp-logout:hover {
      background: #e5e7eb;
    }

    #mca-job-portal-{{ section.id }} .jp-auth-tabs {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      background: #f3f4f6;
      padding: 7px;
      border-radius: 18px;
      margin-bottom: 20px;
    }

    #mca-job-portal-{{ section.id }} .jp-auth-tab {
      border: none;
      border-radius: 13px;
      background: transparent;
      color: var(--muted);
      padding: 12px;
      font-weight: 900;
      cursor: pointer;
      transition: 0.25s ease;
    }

    #mca-job-portal-{{ section.id }} .jp-auth-tab.active {
      background: var(--white);
      color: var(--primary);
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }

    #mca-job-portal-{{ section.id }} .jp-auth-message {
      display: none;
      border-radius: 16px;
      padding: 13px 14px;
      margin-bottom: 16px;
      font-weight: 800;
      line-height: 1.4;
    }

    #mca-job-portal-{{ section.id }} .jp-auth-message.success {
      display: block;
      background: rgba(0,184,148,0.1);
      border: 1px solid rgba(0,184,148,0.25);
      color: #047857;
    }

    #mca-job-portal-{{ section.id }} .jp-auth-message.error {
      display: block;
      background: rgba(239,68,68,0.08);
      border: 1px solid rgba(239,68,68,0.2);
      color: #b91c1c;
    }

    #mca-job-portal-{{ section.id }} .jp-auth-note {
      margin: 14px 0 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.6;
    }

    #mca-job-portal-{{ section.id }} .jp-auth-note strong {
      color: var(--dark);
    }

    #mca-job-portal-{{ section.id }} .jp-hero {
      position: relative;
      padding: 90px 0 60px;
      background:
        radial-gradient(circle at top left, rgba(11,92,255,0.16), transparent 35%),
        radial-gradient(circle at bottom right, rgba(0,184,148,0.16), transparent 35%),
        linear-gradient(180deg, #ffffff, #f5f7fb);
    }

    #mca-job-portal-{{ section.id }} .jp-hero-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 48px;
      align-items: center;
    }

    #mca-job-portal-{{ section.id }} .jp-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(11,92,255,0.09);
      color: var(--primary);
      padding: 9px 14px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 800;
      margin-bottom: 22px;
    }

    #mca-job-portal-{{ section.id }} .jp-hero h1 {
      font-size: clamp(38px, 5vw, 68px);
      line-height: 1.02;
      color: var(--dark);
      margin: 0 0 20px;
      letter-spacing: -2px;
    }

    #mca-job-portal-{{ section.id }} .jp-hero h1 span {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    #mca-job-portal-{{ section.id }} .jp-hero p {
      font-size: 18px;
      line-height: 1.7;
      color: var(--muted);
      max-width: 650px;
      margin: 0 0 30px;
    }

    #mca-job-portal-{{ section.id }} .jp-hero-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    #mca-job-portal-{{ section.id }} .jp-hero-card {
      background: rgba(255,255,255,0.78);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.9);
      border-radius: 32px;
      padding: 26px;
      box-shadow: var(--shadow);
      animation: floatCard 5s ease-in-out infinite;
    }

    #mca-job-portal-{{ section.id }} .jp-profile-card {
      background: var(--white);
      border-radius: 24px;
      padding: 20px;
      border: 1px solid var(--border);
      margin-bottom: 16px;
    }

    #mca-job-portal-{{ section.id }} .jp-profile-top {
      display: flex;
      gap: 14px;
      align-items: center;
      margin-bottom: 18px;
    }

    #mca-job-portal-{{ section.id }} .jp-avatar {
      width: 52px;
      height: 52px;
      border-radius: 16px;
      background: linear-gradient(135deg, #111827, #0b5cff);
      color: white;
      display: grid;
      place-items: center;
      font-weight: 900;
    }

    #mca-job-portal-{{ section.id }} .jp-profile-card h3 {
      margin: 0;
      color: var(--dark);
      font-size: 18px;
    }

    #mca-job-portal-{{ section.id }} .jp-profile-card p {
      margin: 4px 0 0;
      font-size: 13px;
      color: var(--muted);
    }

    #mca-job-portal-{{ section.id }} .jp-progress {
      height: 9px;
      background: #eef2ff;
      border-radius: 999px;
      overflow: hidden;
    }

    #mca-job-portal-{{ section.id }} .jp-progress span {
      display: block;
      width: 82%;
      height: 100%;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      border-radius: 999px;
    }

    #mca-job-portal-{{ section.id }} .jp-mini-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }

    #mca-job-portal-{{ section.id }} .jp-mini-box {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 18px;
    }

    #mca-job-portal-{{ section.id }} .jp-mini-box strong {
      display: block;
      color: var(--dark);
      font-size: 26px;
      margin-bottom: 4px;
    }

    #mca-job-portal-{{ section.id }} .jp-mini-box span {
      font-size: 13px;
      color: var(--muted);
      font-weight: 700;
    }

    #mca-job-portal-{{ section.id }} .jp-section {
      padding: 76px 0;
    }

    #mca-job-portal-{{ section.id }} .jp-section-title {
      text-align: center;
      max-width: 760px;
      margin: 0 auto 38px;
    }

    #mca-job-portal-{{ section.id }} .jp-section-title h2 {
      font-size: clamp(30px, 4vw, 46px);
      color: var(--dark);
      margin: 0 0 12px;
      letter-spacing: -1px;
    }

    #mca-job-portal-{{ section.id }} .jp-section-title p {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
      font-size: 16px;
    }

    #mca-job-portal-{{ section.id }} .jp-search-panel {
      background: var(--white);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      border-radius: 28px;
      padding: 22px;
      margin-bottom: 32px;
    }

    #mca-job-portal-{{ section.id }} .jp-search-grid {
      display: grid;
      grid-template-columns: 1.3fr 1fr 1fr 1fr auto;
      gap: 12px;
    }

    #mca-job-portal-{{ section.id }} input,
    #mca-job-portal-{{ section.id }} select,
    #mca-job-portal-{{ section.id }} textarea {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px 15px;
      font-size: 14px;
      outline: none;
      background: white;
      color: var(--text);
      transition: 0.25s ease;
    }

    #mca-job-portal-{{ section.id }} input:focus,
    #mca-job-portal-{{ section.id }} select:focus,
    #mca-job-portal-{{ section.id }} textarea:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 4px rgba(11,92,255,0.10);
    }

    #mca-job-portal-{{ section.id }} .jp-jobs-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }

    #mca-job-portal-{{ section.id }} .jp-job-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 26px;
      padding: 22px;
      transition: 0.35s ease;
      position: relative;
      overflow: hidden;
    }

    #mca-job-portal-{{ section.id }} .jp-job-card::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(11,92,255,0.08), rgba(0,184,148,0.08));
      opacity: 0;
      transition: 0.35s ease;
      pointer-events: none;
    }

    #mca-job-portal-{{ section.id }} .jp-job-card:hover {
      transform: translateY(-8px);
      box-shadow: var(--shadow);
      border-color: rgba(11,92,255,0.3);
    }

    #mca-job-portal-{{ section.id }} .jp-job-card:hover::before {
      opacity: 1;
    }

    #mca-job-portal-{{ section.id }} .jp-job-inner {
      position: relative;
      z-index: 2;
    }

    #mca-job-portal-{{ section.id }} .jp-job-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 16px;
    }

    #mca-job-portal-{{ section.id }} .jp-company-icon {
      width: 48px;
      height: 48px;
      border-radius: 16px;
      background: #eef2ff;
      color: var(--primary);
      display: grid;
      place-items: center;
      font-weight: 900;
      font-size: 18px;
    }

    #mca-job-portal-{{ section.id }} .jp-save {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: 1px solid var(--border);
      background: white;
      cursor: pointer;
    }

    #mca-job-portal-{{ section.id }} .jp-job-card h3 {
      margin: 0 0 8px;
      color: var(--dark);
      font-size: 20px;
    }

    #mca-job-portal-{{ section.id }} .jp-company {
      font-size: 14px;
      color: var(--muted);
      margin-bottom: 16px;
      font-weight: 700;
    }

    #mca-job-portal-{{ section.id }} .jp-tags {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }

    #mca-job-portal-{{ section.id }} .jp-tag {
      font-size: 12px;
      font-weight: 800;
      color: var(--primary);
      background: rgba(11,92,255,0.09);
      padding: 7px 10px;
      border-radius: 999px;
    }

    #mca-job-portal-{{ section.id }} .jp-job-meta {
      display: grid;
      gap: 8px;
      margin-bottom: 20px;
      font-size: 14px;
      color: var(--muted);
    }

    #mca-job-portal-{{ section.id }} .jp-job-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border-top: 1px solid var(--border);
      padding-top: 16px;
    }

    #mca-job-portal-{{ section.id }} .jp-salary {
      font-weight: 900;
      color: var(--dark);
    }

    #mca-job-portal-{{ section.id }} .jp-apply-btn {
      border: none;
      background: var(--dark);
      color: white;
      padding: 11px 15px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.3s ease;
    }

    #mca-job-portal-{{ section.id }} .jp-apply-btn:hover {
      background: var(--primary);
    }

    #mca-job-portal-{{ section.id }} .jp-empty {
      display: none;
      text-align: center;
      padding: 30px;
      background: white;
      border-radius: 22px;
      border: 1px dashed var(--border);
      color: var(--muted);
      margin-top: 20px;
    }

    #mca-job-portal-{{ section.id }} .jp-category-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
    }

    #mca-job-portal-{{ section.id }} .jp-category {
      background: white;
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 24px;
      transition: 0.3s ease;
    }

    #mca-job-portal-{{ section.id }} .jp-category:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow);
    }

    #mca-job-portal-{{ section.id }} .jp-category-icon {
      width: 52px;
      height: 52px;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(11,92,255,0.14), rgba(0,184,148,0.14));
      display: grid;
      place-items: center;
      font-size: 24px;
      margin-bottom: 18px;
    }

    #mca-job-portal-{{ section.id }} .jp-category h3 {
      color: var(--dark);
      margin: 0 0 8px;
    }

    #mca-job-portal-{{ section.id }} .jp-category p {
      margin: 0;
      color: var(--muted);
      line-height: 1.5;
      font-size: 14px;
    }

    #mca-job-portal-{{ section.id }} .jp-news-wrap {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }

    #mca-job-portal-{{ section.id }} .jp-news-main,
    #mca-job-portal-{{ section.id }} .jp-side-card {
      background: white;
      border: 1px solid var(--border);
      border-radius: 28px;
      padding: 28px;
      box-shadow: 0 12px 35px rgba(15,23,42,0.06);
    }

    #mca-job-portal-{{ section.id }} .jp-news-main h3,
    #mca-job-portal-{{ section.id }} .jp-side-card h3 {
      margin: 0 0 14px;
      color: var(--dark);
      font-size: 26px;
    }

    #mca-job-portal-{{ section.id }} .jp-news-main p,
    #mca-job-portal-{{ section.id }} .jp-side-card p {
      color: var(--muted);
      line-height: 1.7;
      margin: 0 0 16px;
    }

    #mca-job-portal-{{ section.id }} .jp-news-list {
      display: grid;
      gap: 14px;
    }

    #mca-job-portal-{{ section.id }} .jp-news-item {
      display: grid;
      grid-template-columns: 70px 1fr;
      gap: 14px;
      align-items: center;
      padding: 14px;
      border: 1px solid var(--border);
      border-radius: 18px;
      background: #fafafa;
    }

    #mca-job-portal-{{ section.id }} .jp-date {
      background: var(--dark);
      color: white;
      border-radius: 14px;
      padding: 10px;
      text-align: center;
      font-weight: 900;
      font-size: 13px;
    }

    #mca-job-portal-{{ section.id }} .jp-news-item h4 {
      margin: 0 0 4px;
      color: var(--dark);
      font-size: 15px;
    }

    #mca-job-portal-{{ section.id }} .jp-news-item span {
      font-size: 13px;
      color: var(--muted);
    }

    #mca-job-portal-{{ section.id }} .jp-blog-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }

    #mca-job-portal-{{ section.id }} .jp-blog {
      background: white;
      border: 1px solid var(--border);
      border-radius: 26px;
      overflow: hidden;
      transition: 0.3s ease;
    }

    #mca-job-portal-{{ section.id }} .jp-blog:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow);
    }

    #mca-job-portal-{{ section.id }} .jp-blog-img {
      height: 170px;
      background:
        linear-gradient(135deg, rgba(11,92,255,0.9), rgba(0,184,148,0.8)),
        repeating-linear-gradient(45deg, transparent, transparent 8px, rgba(255,255,255,0.12) 8px, rgba(255,255,255,0.12) 16px);
      display: grid;
      place-items: center;
      color: white;
      font-size: 42px;
    }

    #mca-job-portal-{{ section.id }} .jp-blog-content {
      padding: 22px;
    }

    #mca-job-portal-{{ section.id }} .jp-blog-content h3 {
      color: var(--dark);
      margin: 0 0 10px;
      font-size: 20px;
    }

    #mca-job-portal-{{ section.id }} .jp-blog-content p {
      margin: 0 0 16px;
      color: var(--muted);
      line-height: 1.6;
      font-size: 14px;
    }

    #mca-job-portal-{{ section.id }} .jp-trending {
      background: var(--dark);
      color: white;
      border-radius: 34px;
      padding: 38px;
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 32px;
      align-items: center;
      overflow: hidden;
      position: relative;
    }

    #mca-job-portal-{{ section.id }} .jp-trending::after {
      content: "";
      position: absolute;
      width: 320px;
      height: 320px;
      border-radius: 50%;
      background: rgba(11,92,255,0.25);
      right: -90px;
      top: -110px;
    }

    #mca-job-portal-{{ section.id }} .jp-trending h2 {
      margin: 0 0 12px;
      color: white;
      font-size: 36px;
    }

    #mca-job-portal-{{ section.id }} .jp-trending p {
      color: #cbd5e1;
      line-height: 1.7;
      margin: 0;
    }

    #mca-job-portal-{{ section.id }} .jp-skill-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      position: relative;
      z-index: 2;
    }

    #mca-job-portal-{{ section.id }} .jp-skill {
      background: rgba(255,255,255,0.1);
