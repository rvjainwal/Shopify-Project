          <div class="jp-blog-img">🎯</div>
          <div class="jp-blog-content">
            <h3>Top Interview Questions for MCA Students</h3>
            <p>Prepare for technical and HR interview rounds with common fresher-level questions.</p>
            <a href="#apply" class="jp-btn secondary">Read More</a>
          </div>
        </article>

        <article class="jp-blog reveal">
          <div class="jp-blog-img">🚀</div>
          <div class="jp-blog-content">
            <h3>Best Skills for 2026 Hiring</h3>
            <p>Understand which technical and soft skills can improve your chances of shortlisting.</p>
            <a href="#apply" class="jp-btn secondary">Read More</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="jp-section">
    <div class="jp-container">
      <div class="jp-section-title reveal">
        <h2>How CareerConnect Works</h2>
        <p>A simple flow for candidates, recruiters, and college placement teams.</p>
      </div>

      <div class="jp-steps">
        <div class="jp-step reveal">
          <div class="jp-step-num">1</div>
          <h3>Search Jobs</h3>
          <p>Users can search and filter opportunities by title, category, city, and job type.</p>
        </div>

        <div class="jp-step reveal">
          <div class="jp-step-num">2</div>
          <h3>View Details</h3>
          <p>Every card shows company, skills, salary, location, eligibility, and work mode.</p>
        </div>

        <div class="jp-step reveal">
          <div class="jp-step-num">3</div>
          <h3>Apply Online</h3>
          <p>Candidate details are submitted using Shopify’s contact form system.</p>
        </div>

        <div class="jp-step reveal">
          <div class="jp-step-num">4</div>
          <h3>Recruiter Review</h3>
          <p>Store admin receives the application details through Shopify contact email.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="apply" class="jp-footer">
    <div class="jp-container">
      <h3>CareerConnect Job Portal System</h3>
      <p>MCA Final Year Project • Single Page Website • Job Search • Blogs • Job News • Shopify Contact Form</p>
    </div>
  </section>

  <div class="jp-modal" id="jpApplyModal-{{ section.id }}">
    <div class="jp-modal-box">
      <div class="jp-modal-head">
        <div>
          <h3>Apply for Job</h3>
          <p id="jpSelectedJobText-{{ section.id }}">Fill your details and submit your application.</p>
        </div>
        <button type="button" class="jp-close" id="jpCloseModal-{{ section.id }}">×</button>
      </div>

      {% form 'contact', id: 'JobApplicationForm' %}

        {% if form.posted_successfully? %}
          <div class="jp-success">
            Thank you. Your job application has been submitted successfully.
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="jp-error">
            Please check the required fields and submit again.
          </div>
        {% endif %}

        <input type="hidden" name="contact[Form Type]" value="Job Application">
        <input type="hidden" name="contact[Applied Job]" id="jpAppliedJob-{{ section.id }}" value="General Application">

        <div class="jp-form-grid">
          <div class="jp-form-field">
            <label>Full Name *</label>
            <input type="text" name="contact[name]" required placeholder="Enter your full name">
          </div>

          <div class="jp-form-field">
            <label>Email Address *</label>
            <input type="email" name="contact[email]" required placeholder="Enter your email">
          </div>

          <div class="jp-form-field">
            <label>Phone Number *</label>
            <input type="tel" name="contact[phone]" required placeholder="Enter your phone number">
          </div>

          <div class="jp-form-field">
            <label>Highest Qualification</label>
            <input type="text" name="contact[Highest Qualification]" placeholder="MCA, BCA, MBA, B.Tech">
          </div>

          <div class="jp-form-field">
            <label>Experience</label>
            <select name="contact[Experience]">
              <option value="Fresher">Fresher</option>
              <option value="0-1 Year">0-1 Year</option>
              <option value="1-3 Years">1-3 Years</option>
              <option value="3+ Years">3+ Years</option>
            </select>
          </div>

          <div class="jp-form-field">
            <label>Current Location</label>
            <input type="text" name="contact[Current Location]" placeholder="City, State">
          </div>

          <div class="jp-form-field full">
            <label>Resume / Portfolio URL</label>
            <input type="url" name="contact[Resume URL]" placeholder="Google Drive, LinkedIn, portfolio link">
          </div>

          <div class="jp-form-field full">
            <label>Cover Message</label>
            <textarea name="contact[body]" placeholder="Write a short message about your skills, project experience, and job interest."></textarea>
          </div>

          <div class="jp-form-field full">
            <button type="submit" class="jp-btn">Submit Application</button>
          </div>
        </div>

      {% endform %}
    </div>
  </div>

  <div class="jp-modal" id="jpAuthModal-{{ section.id }}">
    <div class="jp-modal-box">
      <div class="jp-modal-head">
        <div>
          <h3 id="jpAuthTitle-{{ section.id }}">Candidate Login</h3>
          <p id="jpAuthSubText-{{ section.id }}">Login to apply faster and save your favourite jobs.</p>
        </div>
        <button type="button" class="jp-close" id="jpCloseAuthModal-{{ section.id }}">×</button>
      </div>

      <div class="jp-auth-tabs">
        <button type="button" class="jp-auth-tab active" data-auth-tab="login">Login</button>
        <button type="button" class="jp-auth-tab" data-auth-tab="register">Register</button>
      </div>

      <div class="jp-auth-message" id="jpAuthMessage-{{ section.id }}"></div>

      <form class="jp-auth-form jp-form-grid" id="jpLoginForm-{{ section.id }}">
        <div class="jp-form-field full">
          <label>Email Address *</label>
          <input type="email" id="jpLoginEmail-{{ section.id }}" placeholder="Enter your registered email" required>
        </div>

        <div class="jp-form-field full">
          <label>Password *</label>
          <input type="password" id="jpLoginPassword-{{ section.id }}" placeholder="Enter your password" required>
        </div>

        <div class="jp-form-field full">
          <button type="submit" class="jp-btn">Login</button>
          <p class="jp-auth-note">
            Demo account data is saved in this browser using localStorage for MCA project presentation.
          </p>
        </div>
      </form>

      <form class="jp-auth-form jp-form-grid" id="jpRegisterForm-{{ section.id }}" style="display:none;">
        <div class="jp-form-field">
          <label>Full Name *</label>
          <input type="text" id="jpRegisterName-{{ section.id }}" placeholder="Enter your full name" required>
        </div>

        <div class="jp-form-field">
          <label>Email Address *</label>
          <input type="email" id="jpRegisterEmail-{{ section.id }}" placeholder="Enter your email" required>
        </div>

        <div class="jp-form-field">
          <label>Phone Number</label>
          <input type="tel" id="jpRegisterPhone-{{ section.id }}" placeholder="Enter your phone number">
        </div>

        <div class="jp-form-field">
          <label>Qualification</label>
          <input type="text" id="jpRegisterQualification-{{ section.id }}" placeholder="MCA, BCA, MBA, B.Tech">
        </div>

        <div class="jp-form-field full">
          <label>Password *</label>
          <input type="password" id="jpRegisterPassword-{{ section.id }}" placeholder="Create minimum 6 character password" required>
        </div>

        <div class="jp-form-field full">
          <button type="submit" class="jp-btn">Create Account</button>
          <p class="jp-auth-note">
            <strong>Note:</strong> This is frontend demo login/registration. For live Shopify customer accounts, connect this with Shopify customer registration/login templates or an app backend.
          </p>
        </div>
      </form>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const root = document.querySelector('#mca-job-portal-{{ section.id }}');
      if (!root) return;

      const searchInput = root.querySelector('#jpSearchInput-{{ section.id }}');
      const categoryFilter = root.querySelector('#jpCategoryFilter-{{ section.id }}');
      const locationFilter = root.querySelector('#jpLocationFilter-{{ section.id }}');
      const typeFilter = root.querySelector('#jpTypeFilter-{{ section.id }}');
      const resetBtn = root.querySelector('#jpResetBtn-{{ section.id }}');
      const jobs = Array.from(root.querySelectorAll('.jp-job-card'));
      const emptyBox = root.querySelector('#jpEmpty-{{ section.id }}');

      function filterJobs() {
        const searchValue = searchInput.value.toLowerCase().trim();
        const categoryValue = categoryFilter.value;
        const locationValue = locationFilter.value;
        const typeValue = typeFilter.value;

        let visibleCount = 0;

        jobs.forEach(function (job) {
          const title = job.dataset.title.toLowerCase();
          const company = job.dataset.company.toLowerCase();
          const category = job.dataset.category;
          const location = job.dataset.location;
          const type = job.dataset.type;

          const matchSearch = !searchValue || title.includes(searchValue) || company.includes(searchValue);
          const matchCategory = !categoryValue || category === categoryValue;
          const matchLocation = !locationValue || location === locationValue;
          const matchType = !typeValue || type === typeValue;

          if (matchSearch && matchCategory && matchLocation && matchType) {
            job.style.display = '';
            visibleCount++;
          } else {
            job.style.display = 'none';
          }
        });

        emptyBox.style.display = visibleCount === 0 ? 'block' : 'none';
      }

      [searchInput, categoryFilter, locationFilter, typeFilter].forEach(function (item) {
        item.addEventListener('input', filterJobs);
        item.addEventListener('change', filterJobs);
      });

      resetBtn.addEventListener('click', function () {
        searchInput.value = '';
        categoryFilter.value = '';
        locationFilter.value = '';
        typeFilter.value = '';
        filterJobs();
      });

      const modal = root.querySelector('#jpApplyModal-{{ section.id }}');
      const closeModal = root.querySelector('#jpCloseModal-{{ section.id }}');
      const selectedJobText = root.querySelector('#jpSelectedJobText-{{ section.id }}');
      const appliedJobInput = root.querySelector('#jpAppliedJob-{{ section.id }}');

      const authModal = root.querySelector('#jpAuthModal-{{ section.id }}');
      const closeAuthModal = root.querySelector('#jpCloseAuthModal-{{ section.id }}');
      const authTitle = root.querySelector('#jpAuthTitle-{{ section.id }}');
      const authSubText = root.querySelector('#jpAuthSubText-{{ section.id }}');
      const authMessage = root.querySelector('#jpAuthMessage-{{ section.id }}');
      const loginForm = root.querySelector('#jpLoginForm-{{ section.id }}');
      const registerForm = root.querySelector('#jpRegisterForm-{{ section.id }}');
      const userChip = root.querySelector('#jpUserChip-{{ section.id }}');
      const userAvatar = root.querySelector('#jpUserAvatar-{{ section.id }}');
      const loggedUserName = root.querySelector('#jpLoggedUserName-{{ section.id }}');
      const logoutBtn = root.querySelector('#jpLogoutBtn-{{ section.id }}');
      const profileName = root.querySelector('#jpProfileName-{{ section.id }}');
      const profileStatus = root.querySelector('#jpProfileStatus-{{ section.id }}');

      const usersKey = 'careerConnectUsers';
      const sessionKey = 'careerConnectCurrentUser';
      let pendingApplyJob = null;

      function getStoredData(key, fallback) {
        try {
          const value = localStorage.getItem(key);
          return value ? JSON.parse(value) : fallback;
        } catch (error) {
          return fallback;
        }
      }

      function setStoredData(key, value) {
        try {
          localStorage.setItem(key, JSON.stringify(value));
        } catch (error) {
          console.warn('CareerConnect storage unavailable');
        }
      }

      function removeStoredData(key) {
        try {
          localStorage.removeItem(key);
        } catch (error) {
          console.warn('CareerConnect storage unavailable');
        }
      }

      function getUsers() {
        return getStoredData(usersKey, []);
      }

      function saveUsers(users) {
        setStoredData(usersKey, users);
      }

      function getCurrentUser() {
        return getStoredData(sessionKey, null);
      }

      function setCurrentUser(user) {
        setStoredData(sessionKey, user);
        updateAuthUI();
      }

      function showAuthMessage(message, type) {
        authMessage.textContent = message;
        authMessage.className = 'jp-auth-message ' + type;
      }

      function clearAuthMessage() {
        authMessage.textContent = '';
        authMessage.className = 'jp-auth-message';
      }

      function setAuthMode(mode) {
        const isLogin = mode === 'login';

        root.querySelectorAll('.jp-auth-tab').forEach(function (tab) {
          tab.classList.toggle('active', tab.getAttribute('data-auth-tab') === mode);
        });

        loginForm.style.display = isLogin ? 'grid' : 'none';
        registerForm.style.display = isLogin ? 'none' : 'grid';
        authTitle.textContent = isLogin ? 'Candidate Login' : 'Candidate Registration';
        authSubText.textContent = isLogin
          ? 'Login to apply faster and save your favourite jobs.'
          : 'Create your candidate account and start applying for jobs.';
        clearAuthMessage();
      }

      function openAuthModal(mode, message, type) {
        setAuthMode(mode || 'login');
        authModal.classList.add('active');

        if (message) {
          showAuthMessage(message, type || 'error');
        }
      }

      function closeAuth() {
        authModal.classList.remove('active');
      }

      function updateAuthUI() {
        const currentUser = getCurrentUser();
        const authButtons = root.querySelectorAll('.jp-open-auth');

        if (currentUser) {
          authButtons.forEach(function (button) {
            button.style.display = 'none';
          });

          userChip.classList.add('active');
          userAvatar.textContent = currentUser.name ? currentUser.name.charAt(0).toUpperCase() : 'U';
          loggedUserName.textContent = currentUser.name || 'Candidate';

          if (profileName) {
            profileName.textContent = currentUser.name || 'Applicant Profile';
          }

          if (profileStatus) {
            profileStatus.textContent = 'Profile logged in • Ready to apply';
          }
        } else {
          authButtons.forEach(function (button) {
            button.style.display = '';
          });

          userChip.classList.remove('active');
          userAvatar.textContent = 'U';
          loggedUserName.textContent = 'Candidate';

          if (profileName) {
            profileName.textContent = 'Applicant Profile';
          }

          if (profileStatus) {
            profileStatus.textContent = 'Login or register to complete your profile';
          }
        }
      }

      function fillApplicationForm() {
        const currentUser = getCurrentUser();
        if (!currentUser) return;

        const nameInput = root.querySelector('input[name="contact[name]"]');
        const emailInput = root.querySelector('input[name="contact[email]"]');
        const phoneInput = root.querySelector('input[name="contact[phone]"]');
        const qualificationInput = root.querySelector('input[name="contact[Highest Qualification]"]');

        if (nameInput && !nameInput.value) nameInput.value = currentUser.name || '';
        if (emailInput && !emailInput.value) emailInput.value = currentUser.email || '';
        if (phoneInput && !phoneInput.value) phoneInput.value = currentUser.phone || '';
        if (qualificationInput && !qualificationInput.value) qualificationInput.value = currentUser.qualification || '';
      }

      function openApplyModal(jobName) {
        selectedJobText.textContent = 'Selected role: ' + jobName;
        appliedJobInput.value = jobName;
        fillApplicationForm();
        modal.classList.add('active');
      }

      root.querySelectorAll('.jp-open-auth').forEach(function (button) {
        button.addEventListener('click', function () {
          openAuthModal(button.getAttribute('data-auth') || 'login');
        });
      });

      root.querySelectorAll('.jp-auth-tab').forEach(function (tab) {
        tab.addEventListener('click', function () {
          setAuthMode(tab.getAttribute('data-auth-tab'));
        });
      });

      registerForm.addEventListener('submit', function (event) {
        event.preventDefault();

        const name = root.querySelector('#jpRegisterName-{{ section.id }}').value.trim();
        const email = root.querySelector('#jpRegisterEmail-{{ section.id }}').value.trim().toLowerCase();
        const phone = root.querySelector('#jpRegisterPhone-{{ section.id }}').value.trim();
        const qualification = root.querySelector('#jpRegisterQualification-{{ section.id }}').value.trim();
        const password = root.querySelector('#jpRegisterPassword-{{ section.id }}').value.trim();

        if (!name || !email || !password) {
          showAuthMessage('Please enter name, email, and password.', 'error');
          return;
        }

        if (password.length < 6) {
          showAuthMessage('Password must be at least 6 characters long.', 'error');
          return;
        }

        const users = getUsers();
        const alreadyExists = users.some(function (user) {
          return user.email === email;
        });

        if (alreadyExists) {
          setAuthMode('login');
          root.querySelector('#jpLoginEmail-{{ section.id }}').value = email;
          showAuthMessage('This email is already registered. Please login instead.', 'error');
          return;
        }

        const newUser = {
          name: name,
          email: email,
          phone: phone,
          qualification: qualification,
          password: password,
          createdAt: new Date().toISOString()
        };

        users.push(newUser);
        saveUsers(users);

        setCurrentUser({
          name: name,
          email: email,
          phone: phone,
          qualification: qualification
        });

        registerForm.reset();
        showAuthMessage('Registration successful. You are now logged in.', 'success');

        if (pendingApplyJob) {
          const jobToOpen = pendingApplyJob;
          pendingApplyJob = null;

          setTimeout(function () {
            closeAuth();
            openApplyModal(jobToOpen);
          }, 500);
        }
      });

      loginForm.addEventListener('submit', function (event) {
        event.preventDefault();

        const email = root.querySelector('#jpLoginEmail-{{ section.id }}').value.trim().toLowerCase();
        const password = root.querySelector('#jpLoginPassword-{{ section.id }}').value.trim();

        if (!email || !password) {
          showAuthMessage('Please enter email and password.', 'error');
          return;
        }

        const users = getUsers();
        const matchedUser = users.find(function (user) {
          return user.email === email && user.password === password;
        });

        if (!matchedUser) {
          showAuthMessage('Invalid login details. Please register first or check your password.', 'error');
          return;
        }

        setCurrentUser({
          name: matchedUser.name,
          email: matchedUser.email,
          phone: matchedUser.phone,
          qualification: matchedUser.qualification
        });

        loginForm.reset();
        showAuthMessage('Login successful.', 'success');

        if (pendingApplyJob) {
          const jobToOpen = pendingApplyJob;
          pendingApplyJob = null;

          setTimeout(function () {
            closeAuth();
            openApplyModal(jobToOpen);
          }, 500);
        } else {
          setTimeout(closeAuth, 650);
        }
      });

      logoutBtn.addEventListener('click', function () {
        removeStoredData(sessionKey);
        updateAuthUI();
      });

      root.querySelectorAll('.jp-open-apply').forEach(function (button) {
        button.addEventListener('click', function () {
          const jobName = button.getAttribute('data-job') || 'General Application';

          if (!getCurrentUser()) {
            pendingApplyJob = jobName;
            openAuthModal('login', 'Please login or register before applying for this job.', 'error');
            return;
          }

          openApplyModal(jobName);
        });
      });

      closeModal.addEventListener('click', function () {
        modal.classList.remove('active');
      });

      closeAuthModal.addEventListener('click', closeAuth);

      modal.addEventListener('click', function (event) {
        if (event.target === modal) {
          modal.classList.remove('active');
        }
      });

      authModal.addEventListener('click', function (event) {
        if (event.target === authModal) {
          closeAuth();
        }
      });

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
          modal.classList.remove('active');
          closeAuth();
        }
      });

      root.querySelectorAll('.jp-save').forEach(function (button) {
        button.addEventListener('click', function () {
          if (!getCurrentUser()) {
            openAuthModal('login', 'Please login before saving a job.', 'error');
            return;
          }

          button.textContent = button.textContent === '♡' ? '♥' : '♡';
        });
      });

      updateAuthUI();

      const revealItems = root.querySelectorAll('.reveal');

      const observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      }, {
        threshold: 0.12
      });

      revealItems.forEach(function (item) {
        observer.observe(item);
      });
    });
  </script>

</section>

