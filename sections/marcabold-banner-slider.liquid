{% liquid
  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif

  assign slide_count = section.blocks.size
  if slide_count == 0
    assign slide_count = 1
  endif
%}

<marcabold-banner-slider
  id="MarcaboldBannerSlider-{{ section.id }}"
  class="marcabold-banner-slider"
  data-autoplay="{{ section.settings.autoplay }}"
  data-interval="{{ section.settings.autoplay_interval | times: 1000 }}"
  style="
    --mbs-height: {{ section.settings.desktop_height }}px;
    --mbs-mobile-height: {{ section.settings.mobile_height }}px;
    --mbs-radius: {{ section.settings.corner_radius }}px;
    --mbs-content-bottom: {{ section.settings.content_bottom }}px;
    --mbs-mobile-content-bottom: {{ section.settings.mobile_content_bottom }}px;
    --mbs-content-width: {{ section.settings.content_max_width }}px;
    --mbs-title-size: {{ section.settings.title_size }}px;
    --mbs-mobile-title-size: {{ section.settings.mobile_title_size }}px;
    --mbs-subtitle-size: {{ section.settings.subtitle_size }}px;
    --mbs-mobile-subtitle-size: {{ section.settings.mobile_subtitle_size }}px;
    --mbs-text-color: {{ section.settings.text_color }};
    --mbs-button-bg: {{ section.settings.button_background }};
    --mbs-button-text: {{ section.settings.button_text_color }};
    --mbs-dot-color: {{ section.settings.dot_color }};
    --mbs-dot-inactive: {{ section.settings.dot_inactive_color }};
    --mbs-dot-inactive-opacity: {{ section.settings.dot_inactive_opacity | divided_by: 100.0 }};
    --mbs-fade-opacity: {{ section.settings.fade_opacity | divided_by: 100.0 }};
  "
>
  <div class="marcabold-banner-slider__viewport">
    <div
      class="marcabold-banner-slider__track"
      data-slider-track
      role="list"
      aria-label="{{ section.settings.accessibility_label | escape }}"
    >
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% liquid
            assign slide_link = block.settings.link
            assign button_link = block.settings.button_link
            if button_link == blank
              assign button_link = slide_link
            endif

            assign image_alt = block.settings.image.alt | default: block.settings.title
            if image_alt == blank
              assign image_alt = shop.name
            endif

            assign desktop_fallback_asset = block.settings.desktop_fallback_asset
            if desktop_fallback_asset == blank
              assign desktop_fallback_asset = 'marcabold-hero.png'
            endif

            assign mobile_fallback_asset = block.settings.mobile_fallback_asset
            if mobile_fallback_asset == blank
              assign mobile_fallback_asset = desktop_fallback_asset
            endif

            assign slide_label = block.settings.title | default: 'Banner slide'
            assign slide_loading = 'lazy'
            assign slide_fetch_priority = 'auto'
            if forloop.first
              assign slide_loading = 'eager'
              assign slide_fetch_priority = fetch_priority
            endif
          %}

          <div
            class="marcabold-banner-slider__slide"
            data-slider-slide
            role="listitem"
            {{ block.shopify_attributes }}
          >
            <picture class="marcabold-banner-slider__media">
              {% if block.settings.mobile_image != blank %}
                <source
                  media="(max-width: 749px)"
                  srcset="
                    {{ block.settings.mobile_image | image_url: width: 375 }} 375w,
                    {{ block.settings.mobile_image | image_url: width: 750 }} 750w,
                    {{ block.settings.mobile_image | image_url: width: 1100 }} 1100w
                  "
                  sizes="100vw"
                >
              {% elsif mobile_fallback_asset != blank %}
                <source
                  media="(max-width: 749px)"
                  srcset="{{ mobile_fallback_asset | asset_url }}"
                  sizes="100vw"
                >
              {% endif %}

              {% if block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 3840
                  | image_tag:
                    widths: '750, 1100, 1440, 1800, 2200, 2880, 3840',
                    sizes: '100vw',
                    class: 'marcabold-banner-slider__image',
                    loading: slide_loading,
                    fetchpriority: slide_fetch_priority,
                    alt: image_alt
                }}
              {% else %}
                <img
                  class="marcabold-banner-slider__image"
                  src="{{ desktop_fallback_asset | asset_url }}"
                  alt="{{ image_alt | escape }}"
                  width="1440"
                  height="704"
                  loading="{{ slide_loading }}"
                  fetchpriority="{{ slide_fetch_priority }}"
                >
              {% endif %}
            </picture>

            <span class="marcabold-banner-slider__fade" aria-hidden="true"></span>

            {% if slide_link != blank %}
              <a
                class="marcabold-banner-slider__slide-link"
                href="{{ slide_link }}"
                aria-label="{{ slide_label | escape }}"
                {% if block.settings.open_in_new_tab %}
                  target="_blank" rel="noopener noreferrer"
                {% endif %}
              ></a>
            {% endif %}

            <div class="marcabold-banner-slider__content">
              {% if block.settings.title != blank %}
                <h2 class="marcabold-banner-slider__title">{{ block.settings.title | escape }}</h2>
              {% endif %}

              {% if block.settings.subtitle != blank %}
                <p class="marcabold-banner-slider__subtitle">{{ block.settings.subtitle | escape }}</p>
              {% endif %}

              {% if block.settings.button_label != blank and button_link != blank %}
                <a
                  class="marcabold-banner-slider__button"
                  href="{{ button_link }}"
                  {% if block.settings.open_in_new_tab %}
                    target="_blank" rel="noopener noreferrer"
                  {% endif %}
                >
                  {{ block.settings.button_label | escape }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% else %}
        <div class="marcabold-banner-slider__slide" data-slider-slide role="listitem">
          <picture class="marcabold-banner-slider__media">
            <img
              class="marcabold-banner-slider__image"
              src="{{ 'marcabold-hero.png' | asset_url }}"
              alt="{{ shop.name | escape }}"
              width="1440"
              height="704"
              loading="eager"
              fetchpriority="{{ fetch_priority }}"
            >
          </picture>
          <span class="marcabold-banner-slider__fade" aria-hidden="true"></span>
          <div class="marcabold-banner-slider__content">
            <h2 class="marcabold-banner-slider__title">FIT BHI. FAB BHI. FINALLY.</h2>
            <p class="marcabold-banner-slider__subtitle">Plus-size streetwear essentials in 2XL-6XL.</p>
            <a class="marcabold-banner-slider__button" href="{{ routes.all_products_collection_url }}">SHOP NOW</a>
          </div>
        </div>
      {% endif %}
    </div>
  </div>

  {% if section.settings.show_dots and slide_count > 1 %}
    <div class="marcabold-banner-slider__dots" role="tablist" aria-label="Banner slides">
      {% for block in section.blocks %}
        <button
          class="marcabold-banner-slider__dot"
          type="button"
          data-slider-dot
          data-slide-index="{{ forloop.index0 }}"
          aria-label="Go to slide {{ forloop.index }}"
          aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
        ></button>
      {% endfor %}
    </div>
  {% endif %}
</marcabold-banner-slider>

<script>
  (() => {
    if (customElements.get('marcabold-banner-slider')) return;

    class MarcaboldBannerSlider extends HTMLElement {
      connectedCallback() {
        this.track = this.querySelector('[data-slider-track]');
        this.slides = Array.from(this.querySelectorAll('[data-slider-slide]'));
        this.dots = Array.from(this.querySelectorAll('[data-slider-dot]'));
        this.currentIndex = 0;
        this.raf = null;
        this.timer = null;

        if (!this.track || this.slides.length === 0) return;

        this.dots.forEach((dot) => {
          dot.addEventListener('click', () => this.goTo(Number(dot.dataset.slideIndex || 0)));
        });

        this.track.addEventListener('scroll', () => this.queueUpdate(), { passive: true });
        window.addEventListener('resize', () => this.queueUpdate(), { passive: true });
        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => this.startAutoplay());
        this.addEventListener('focusin', () => this.stopAutoplay());
        this.addEventListener('focusout', () => this.startAutoplay());

        this.updateDots();
        this.startAutoplay();
      }

      disconnectedCallback() {
        this.stopAutoplay();
        if (this.raf) window.cancelAnimationFrame(this.raf);
      }

      goTo(index) {
        const nextIndex = Math.max(0, Math.min(index, this.slides.length - 1));
        const target = this.slides[nextIndex];
        if (!target) return;

        this.track.scrollTo({
          left: target.offsetLeft,
          behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
        });
        this.currentIndex = nextIndex;
        this.updateDots();
      }

      queueUpdate() {
        if (this.raf) return;
        this.raf = window.requestAnimationFrame(() => {
          this.raf = null;
          this.updateDots();
        });
      }

      updateDots() {
        if (!this.track) return;

        const width = this.track.clientWidth || 1;
        const nextIndex = Math.max(0, Math.min(Math.round(this.track.scrollLeft / width), this.slides.length - 1));
        this.currentIndex = nextIndex;

        this.dots.forEach((dot, index) => {
          dot.setAttribute('aria-current', index === nextIndex ? 'true' : 'false');
        });
      }

      startAutoplay() {
        if (this.dataset.autoplay !== 'true' || this.slides.length < 2 || this.timer) return;

        const interval = Number(this.dataset.interval || 0);
        if (interval < 2000) return;

        this.timer = window.setInterval(() => {
          this.goTo((this.currentIndex + 1) % this.slides.length);
        }, interval);
      }

      stopAutoplay() {
        if (!this.timer) return;
        window.clearInterval(this.timer);
        this.timer = null;
      }
    }

    customElements.define('marcabold-banner-slider', MarcaboldBannerSlider);
  })();
</script>

{% stylesheet %}
  .marcabold-banner-slider {
    position: relative;
    display: block;
    width: 100%;
    background: #efefeb;
  }

  .marcabold-banner-slider__viewport {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: var(--mbs-radius);
    background: #efefeb;
  }

  .marcabold-banner-slider__track {
    display: flex;
    width: 100%;
    min-height: var(--mbs-height);
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .marcabold-banner-slider__track::-webkit-scrollbar {
    display: none;
  }

  .marcabold-banner-slider__slide {
    position: relative;
    flex: 0 0 100%;
    min-width: 100%;
    min-height: var(--mbs-height);
    overflow: hidden;
    scroll-snap-align: start;
    isolation: isolate;
  }

  .marcabold-banner-slider__media,
  .marcabold-banner-slider__image {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
  }

  .marcabold-banner-slider__media {
    z-index: 0;
  }

  .marcabold-banner-slider__image {
    object-fit: cover;
    object-position: center;
  }

  .marcabold-banner-slider__fade {
    position: absolute;
    z-index: 1;
    right: 0;
    bottom: 0;
    left: 0;
    height: 50%;
    background: linear-gradient(180deg, rgb(0 0 0 / 0) 0%, rgb(0 0 0 / var(--mbs-fade-opacity)) 100%);
    pointer-events: none;
  }

  .marcabold-banner-slider__slide-link {
    position: absolute;
    z-index: 2;
    inset: 0;
  }

  .marcabold-banner-slider__content {
    position: absolute;
    z-index: 3;
    left: 50%;
    bottom: var(--mbs-content-bottom);
    width: min(var(--mbs-content-width), calc(100% - 48px));
    color: var(--mbs-text-color);
    text-align: center;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .marcabold-banner-slider__title {
    margin: 0;
    color: inherit;
    font-family: Overpass, Inter, var(--font-heading--family), sans-serif;
    font-size: var(--mbs-title-size);
    font-weight: 800;
    line-height: 54px;
    letter-spacing: 0;
    text-align: center;
    text-wrap: balance;
  }

  .marcabold-banner-slider__subtitle {
    max-width: 620px;
    margin: 6px auto 0;
    color: inherit;
    font-family: Inter, var(--font-body--family), sans-serif;
    font-size: var(--mbs-subtitle-size);
    font-weight: 700;
    line-height: 22px;
    letter-spacing: 0;
    text-align: center;
  }

  .marcabold-banner-slider__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 200px;
    height: 38px;
    margin-top: 22px;
    border-radius: 18px;
    background: var(--mbs-button-bg);
    color: var(--mbs-button-text);
    font-family: Inter, var(--font-body--family), sans-serif;
    font-size: 11px;
    font-weight: 800;
    line-height: 13px;
    letter-spacing: 0;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
    pointer-events: auto;
  }

  .marcabold-banner-slider__dots {
    position: absolute;
    z-index: 5;
    left: 50%;
    bottom: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transform: translateX(-50%);
  }

  .marcabold-banner-slider__dot {
    width: 6px;
    height: 6px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: var(--mbs-dot-inactive);
    opacity: var(--mbs-dot-inactive-opacity);
    cursor: pointer;
    transition: width 160ms ease, background-color 160ms ease, opacity 160ms ease;
  }

  .marcabold-banner-slider__dot[aria-current='true'] {
    width: 24px;
    background: var(--mbs-dot-color);
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .marcabold-banner-slider__viewport {
      border-radius: 0;
    }

    .marcabold-banner-slider__track,
    .marcabold-banner-slider__slide {
      min-height: var(--mbs-mobile-height);
    }

    .marcabold-banner-slider__fade {
      height: 62%;
    }

    .marcabold-banner-slider__content {
      bottom: var(--mbs-mobile-content-bottom);
      width: min(340px, calc(100% - 32px));
    }

    .marcabold-banner-slider__title {
      font-size: var(--mbs-mobile-title-size);
      line-height: 36px;
    }

    .marcabold-banner-slider__subtitle {
      margin-top: 8px;
      font-size: var(--mbs-mobile-subtitle-size);
      line-height: 20px;
    }

    .marcabold-banner-slider__button {
      width: 160px;
      height: 36px;
      margin-top: 18px;
      border-radius: 18px;
    }

    .marcabold-banner-slider__dots {
      bottom: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Marcabold banner slider",
  "tag": "section",
  "class": "marcabold-banner-slider-section",
  "settings": [
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Accessibility label",
      "default": "Promotional banners"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop height",
      "min": 400,
      "max": 800,
      "step": 4,
      "unit": "px",
      "default": 704
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 420,
      "max": 760,
      "step": 4,
      "unit": "px",
      "default": 560
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Desktop corner radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "content_bottom",
      "label": "Desktop content bottom",
      "min": 24,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "mobile_content_bottom",
      "label": "Mobile content bottom",
      "min": 32,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 420,
      "max": 980,
      "step": 20,
      "unit": "px",
      "default": 840
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Desktop title size",
      "min": 28,
      "max": 72,
      "step": 1,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "mobile_title_size",
      "label": "Mobile title size",
      "min": 24,
      "max": 44,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Desktop subtitle size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "mobile_subtitle_size",
      "label": "Mobile subtitle size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "fade_opacity",
      "label": "Bottom fade opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 70
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Autoplay interval",
      "min": 3,
      "max": 9,
      "step": 1,
      "unit": "s",
      "default": 3
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#0b0b0b"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Active dot color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "dot_inactive_color",
      "label": "Inactive dot color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "dot_inactive_opacity",
      "label": "Inactive dot opacity",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "%",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        },
        {
          "type": "text",
          "id": "desktop_fallback_asset",
          "label": "Desktop fallback asset filename",
          "default": "marcabold-hero.png"
        },
        {
          "type": "text",
          "id": "mobile_fallback_asset",
          "label": "Mobile fallback asset filename",
          "default": "marcabold-hero.png"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Image link"
        },
        {
          "type": "checkbox",
          "id": "open_in_new_tab",
          "label": "Open links in a new tab",
          "default": false
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "FIT BHI. FAB BHI. FINALLY."
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subheading",
          "default": "Plus-size streetwear essentials in 2XL-6XL."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marcabold banner slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "title": "FIT BHI. FAB BHI. FINALLY.",
            "subtitle": "Plus-size streetwear essentials in 2XL-6XL.",
            "button_label": "SHOP NOW",
            "button_link": "shopify://collections/all",
            "link": "shopify://collections/all",
            "desktop_fallback_asset": "marcabold-hero.png",
            "mobile_fallback_asset": "marcabold-hero.png"
          }
        },
        {
          "type": "slide",
          "settings": {
            "title": "STREETWEAR THAT FITS.",
            "subtitle": "Bold everyday essentials made for 2XL-6XL.",
            "button_label": "SHOP NOW",
            "button_link": "shopify://collections/all",
            "link": "shopify://collections/all",
            "desktop_fallback_asset": "marcabold-hero-base.png",
            "mobile_fallback_asset": "marcabold-hero-base.png"
          }
        }
      ]
    }
  ]
}
{% endschema %}
